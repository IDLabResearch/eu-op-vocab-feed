LOG_LEVEL=info

# LDES Server variables (also used by the RDF-Connect pipeline)
LDES_BASE_URL=http://localhost:8080
LDES_URL_PATH=/op-vocab-feed
STORE_TYPE=redis
STORE_URL=default:mypassword@192.168.0.178:6379

# RDF-Connect pipeline exclusive variables
VOCAB_SOURCE=https://op.europa.eu/o/opportal-service/euvoc-download-handler?cellarURI=http%3A%2F%2Fpublications.europa.eu%2Fresource%2Fdistribution%2Fcorporate-body%2F20260318-0%2Frdf%2Fskos_core%2Fcorporatebodies-skos.rdf&fileName=corporatebodies-skos.rdf
NODE_HEAP_SIZE=4096

# Redis exclusive variables
REDIS_ARGS="--requirepass mypassword"

# Varnish exclusive variables
VARNISH_SIZE=1G
BACKEND_HOST=192.168.0.178
BACKEND_PORT=3000